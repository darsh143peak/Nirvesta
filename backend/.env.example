NIRVESTA_APP_NAME=Nirvesta API
NIRVESTA_ENV=local
NIRVESTA_API_PREFIX=/api/v1
NIRVESTA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NIRVESTA_MCP_TRANSPORT=stdio
NIRVESTA_TIMEZONE=Asia/Kolkata
NIRVESTA_NSE_BASE_URL=https://www.nseindia.com/api
NIRVESTA_NSE_REFERER=https://www.nseindia.com/
NIRVESTA_MARKET_SYMBOLS=INFY,HDFCBANK,RELIANCE,ITC,SBIN,NIFTYBEES,GOLDBEES,MID150BEES
NIRVESTA_MARKET_CACHE_TTL_SECONDS=60
NIRVESTA_MARKET_REFRESH_INTERVAL_SECONDS=3600
NIRVESTA_ESTIMATED_BROKERAGE_RATE=0.003
NIRVESTA_ESTIMATED_EQUITY_EXIT_FEE_RATE=0.0015
NIRVESTA_ESTIMATED_ETF_EXIT_FEE_RATE=0.0
NIRVESTA_RECOMMENDATION_MONTHLY_CONTRIBUTION=4500
NIRVESTA_REDIS_URL=redis://localhost:6379/0
NIRVESTA_CELERY_BROKER_URL=redis://localhost:6379/0
NIRVESTA_CELERY_RESULT_BACKEND=redis://localhost:6379/0
NIRVESTA_USE_CELERY_SCHEDULER=true
NIRVESTA_N8N_MASTER_FLOW_WEBHOOK_URL=http://127.0.0.1:5678/webhook/master-flow
NIRVESTA_N8N_REQUEST_TIMEOUT_SECONDS=45
NIRVESTA_GROQ_API_KEY=
NIRVESTA_GROQ_BASE_URL=https://api.groq.com/openai/v1
NIRVESTA_GROQ_MODEL=llama-3.3-70b-versatile
